# Server Configuration
HOST=127.0.0.1
PORT=8090
ENVIRONMENT=development
DEBUG=true
ACCESS_LOG=true

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/gonotic?sslmode=disable
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Security Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
CORS_ORIGINS=http://localhost:3000,https://gonotic.com
CORS_ALLOW_CREDENTIALS=true

# Remote STT Service Configuration
REMOTE_WEBSOCKET_URL=ws://localhost:8001/transcribe
REMOTE_REST_URL=http://localhost:8001
REMOTE_TIMEOUT=30
REMOTE_MAX_RETRIES=3

# Enterprise Configuration
ENTERPRISE_MODE=true
ENTERPRISE_API_KEYS=[{"key":"your-api-key-1","name":"key1"},{"key":"your-api-key-2","name":"key2"}]
LOAD_BALANCER_STRATEGY=round_robin
LOAD_BALANCER_MAX_QUEUE_SIZE=100
LOAD_BALANCER_QUEUE_TIMEOUT=30
LOAD_BALANCER_HEALTH_CHECK_INTERVAL=60
LOAD_BALANCER_AUTO_SCALING_ENABLED=false

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BUFFER_SIZE=1024

# STT Configuration
STT_MODEL=whisper-1
STT_AUDIO_FORMAT=auto
STT_LANGUAGE_HINTS=en,zh
STT_ENABLE_PROFANITY_FILTER=false
STT_ENABLE_SPEAKER_DIARIZATION=true
STT_ENABLE_GLOBAL_SPEAKER_IDENTIFICATION=true
STT_ENABLE_SPEAKER_CHANGE_DETECTION=true

# Translation Configuration
TRANSLATION_TYPE=google
TRANSLATION_TARGET_LANGUAGES=zh,en,ja

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/transcribe.log
LOG_MAX_SIZE=5
LOG_BACKUP_COUNT=10
LOG_MAX_AGE_DAYS=30
LOG_COMPRESS=true

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=false
REDIS_BALANCE_CACHE_PREFIX=balance_cache
REDIS_DIAL_TIMEOUT_SECONDS=5
REDIS_SESSION_STORE_ENABLED=false
REDIS_SESSION_STORE_PREFIX=ws_session
REDIS_SESSION_STORE_TTL_SECONDS=86400

# Monitoring Configuration
MONITORING_ENABLED=false
METRICS_ENABLED=false
HEALTH_CHECK_INTERVAL=30

# Storage Configuration (if needed)
TRANSCRIPTION_STORAGE_DIR=./storage/transcriptions
TEMP_AUDIO_DIR=./storage/temp
LOG_STORAGE_DIR=./storage/logs
DATA_STORAGE_DIR=./storage/data
MAX_TRANSCRIPTION_FILE_SIZE=104857600
MAX_TEMP_AUDIO_FILE_SIZE=104857600
ALLOWED_TRANSCRIPTION_TYPES=["application/json","text/plain"]
ALLOWED_AUDIO_TYPES=["audio/wav","audio/mp3","audio/aac","audio/ogg"]
